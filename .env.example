# Ledgr environment variables
# Copy this file to .env.local (gitignored) and fill in real values.
# Never commit real secrets. Keep this template and the runbook.md table in sync.

# --- Database (Neon) ---
# Use the POOLER connection string, never a direct connection (serverless requirement).
# Neon dashboard -> Connection Details -> Pooled connection.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/ledgr?sslmode=require"

# --- Auth (Clerk) ---
# Clerk dashboard -> API Keys. Microsoft is configured as the primary sign-in method.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Optional: override default Clerk redirect routes if needed.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- File storage (Cloudflare R2) ---
# Cloudflare dashboard -> R2. S3-compatible credentials.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ledgr"
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
# Public base URL for CDN-served attachments (custom domain or r2.dev).
R2_PUBLIC_BASE_URL=""

# --- Microsoft Graph (Phase 2: calendar, email-in, OneDrive export) ---
# Azure portal -> App registrations. Not needed for the Phase 1 scaffold.
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""

# --- Todoist (Phase 2) ---
# Todoist -> Settings -> Integrations -> Developer (API token). Not needed for Phase 1.
TODOIST_TOKEN=""

# --- Machine-to-machine tokens (MCP server, cron, webhooks) ---
# Scoped, revocable tokens separate from Clerk. Store hashed server-side.
# Comma-separated for the simple v1 scheme; rotate on any suspicion of leak.
LEDGR_API_TOKENS=""

# --- App config ---
# Toggles verbose errors, query timings, and sync/matcher decisions. Off (false) in normal use.
DEBUG_MODE="false"
# Base URL of the deployed app (used for absolute links, share URLs, callbacks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
