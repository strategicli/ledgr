# Ledgr environment variables
# Copy this file to .env.local (gitignored) and fill in real values.
# Never commit real secrets. Keep this template and the runbook.md table in sync.

# --- Database (Neon) ---
# Use the POOLER connection string, never a direct connection (serverless requirement).
# Neon dashboard -> Connection Details -> Pooled connection.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/ledgr?sslmode=require"

# --- Auth (Clerk) ---
# Clerk dashboard -> API Keys. Microsoft is configured as the only interactive
# sign-in method; sign-ups are restricted (single-user v1).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# The in-app sign-in page (src/app/sign-in). No sign-up page: sign-ups are off.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"

# --- File storage (Cloudflare R2) ---
# Cloudflare dashboard -> R2. S3-compatible credentials.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ledgr"
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
# Public base URL for CDN-served attachments (custom domain or r2.dev).
R2_PUBLIC_BASE_URL=""

# --- Microsoft Graph (OneDrive export now; calendar + email-in in Phase 2) ---
# Azure portal -> App registrations: app-only client credentials (ADR-017).
# The export needs application permission Files.ReadWrite.All with admin
# consent; setup steps in runbook.md §1b.
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
# Whose OneDrive receives the export tree (Brandon's UPN/email) and the
# folder inside it that holds /Export (default "Ledgr" -> /Ledgr/Export/...).
ONEDRIVE_EXPORT_UPN=""
ONEDRIVE_EXPORT_ROOT="Ledgr"
# Mailbox whose calendar/mail the app-only Phase 2 jobs read. Optional:
# defaults to ONEDRIVE_EXPORT_UPN (same person). The Exchange scopes
# (Calendars.Read, Mail.Read) need an Application Access Policy restricting
# this app to this mailbox; setup in runbook.md §1c.
GRAPH_MAILBOX_UPN=""

# --- MCP server (Phase 3, slice 36) ---
# Whose users row the MCP server (POST /api/mcp) acts for. Optional: defaults to
# ONEDRIVE_EXPORT_UPN / GRAPH_MAILBOX_UPN (same person). Needs an `mcp`-scoped
# entry in LEDGR_API_TOKENS to be reachable. Setup: runbook.md §1f.
LEDGR_MCP_OWNER_UPN=""

# --- Todoist (Phase 2, slice 25) ---
# Personal API token: Todoist -> Settings -> Integrations -> Developer.
TODOIST_TOKEN=""
# The Todoist app's client secret, used to verify webhook HMAC signatures.
# Todoist Developer console -> your app -> App Service OAuth / client secret.
TODOIST_CLIENT_SECRET=""
# Optional: which users-row UPN owns the Todoist account for the machine paths
# (cron, webhook). Defaults to ONEDRIVE_EXPORT_UPN (same person).
TODOIST_OWNER_UPN=""

# --- Web Push notifications (Phase 2, slice 30) ---
# VAPID keypair for Web Push (morning agenda, meeting-prep-ready). Generate
# once with `node scripts/make-vapid-keys.mjs`; the public key is also the
# applicationServerKey the browser subscribes with. Setup: runbook.md §1e.
# Without these, /api/push reports unconfigured and the notify crons 503.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact for the push service (RFC 8292 `sub`): mailto: or https URL.
VAPID_SUBJECT="mailto:brandoncollins@edgewoodcommunity.org"

# --- Machine-to-machine tokens (MCP server, cron, webhooks) ---
# Scoped, revocable tokens separate from Clerk; only hashes are stored here.
# Comma-separated entries of name:scope1+scope2:sha256hex, generated with
#   node scripts/make-token.mjs <name> <scope,scope,...>
# Scopes in use: `cron` (scheduled jobs), `diag` (ping), `mcp` (the Claude MCP
# server at /api/mcp — runbook.md §1f). Rotation/revocation flow: runbook.md §3.
LEDGR_API_TOKENS=""

# --- App config ---
# Toggles verbose errors, query timings, and sync/matcher decisions. Off (false) in normal use.
DEBUG_MODE="false"
# IANA timezone that defines "today" (Today view, day-scoped queries). The
# server runs in UTC, so day boundaries must be computed against this;
# defaults to America/New_York when unset. Becomes a per-user setting if
# Ledgr ever goes multi-user.
LEDGR_TIMEZONE="America/New_York"
# Base URL of the deployed app (used for absolute links, share URLs, callbacks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Dev-only auth stand-in (ADR-006): when the Clerk keys above are UNSET and
# NODE_ENV is development, the app treats this email as the signed-in user so
# UI can be exercised locally without a Microsoft sign-in. Ignored in
# production builds. Leave empty normally.
DEV_USER_EMAIL=""
